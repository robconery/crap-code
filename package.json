{
  "name": "bigmachine-fulfillment",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply bigmachine-fulfillment --local"
  },
  "dependencies": {
    "drizzle-orm": "^0.41.0",
    "firebase-admin": "^13.3.0",
    "resend": "^4.5.1",
    "stripe": "^17.7.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250422.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.12.0",
    "bun-types": "latest"
  }
}
