{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "paths": {
      "@mariozechner/pi-coding-agent": [
        "/usr/local/lib/node_modules/@mariozechner/pi-coding-agent/dist/index.d.ts"
      ],
      "typebox": [
        "/usr/local/lib/node_modules/@mariozechner/pi-coding-agent/node_modules/typebox"
      ]
    }
  },
  "include": ["*.ts"]
}
